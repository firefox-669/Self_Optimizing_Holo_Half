# Self_Optimizing_Holo_Half Environment Configuration
# Copy this file to .env and fill in your values

# OpenHands Configuration
OPENHANDS_API_URL=http://localhost:3000
OPENHANDS_API_KEY=your_openhands_api_key_here

# OpenSpace Configuration
OPENSPACE_API_URL=http://localhost:8000
OPENSPACE_API_KEY=your_openspace_api_key_here

# LLM Configuration (for intelligent suggestion generation)
# Choose one provider: openai, anthropic
LLM_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
LLM_MODEL=gpt-4o-mini  # or gpt-4, gpt-3.5-turbo

# Anthropic Configuration (alternative)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
# LLM_MODEL=claude-3-sonnet-20240229

# Custom LLM API (optional, for compatible APIs like Azure, Local LLM)
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=your-custom-api-key

# Database Configuration (optional, defaults to data/holo_half.db)
DATABASE_PATH=data/holo_half.db

# Logging Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Evolution Mode Configuration
EVOLUTION_INTERVAL_HOURS=24
AUTO_APPLY_SUGGESTIONS=false
MAX_CONCURRENT_TESTS=3
